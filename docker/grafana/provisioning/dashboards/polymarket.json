{
  "title": "Polymarket Trader",
  "uid": "polymarket-trader",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Portfolio Equity",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":900},{"color":"green","value":1000}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_portfolio_equity_usd", "legendFormat": "Equity" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat", "title": "Total PnL",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":-10},{"color":"green","value":0}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_portfolio_pnl_usd", "legendFormat": "PnL" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat", "title": "Drawdown",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":0.05},{"color":"red","value":0.08}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_portfolio_drawdown_ratio", "legendFormat": "Drawdown" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat", "title": "Open Positions",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":7}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_open_positions_count", "legendFormat": "Positions" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5, "type": "stat", "title": "WS Connected",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}] }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_ws_connected", "legendFormat": "WS" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6, "type": "stat", "title": "Trades / 5m",
      "gridPos": { "x": 18, "y": 0, "w": 3, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": "Prometheus", "expr": "increase(polymarket_trades_total[5m])", "legendFormat": "Trades" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 10, "type": "timeseries", "title": "Portfolio Equity",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "#5794F2" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_portfolio_equity_usd", "legendFormat": "Equity" }],
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Portfolio Drawdown",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 1.5, "fillOpacity": 20, "gradientMode": "none" },
          "color": { "mode": "fixed", "fixedColor": "#F2495C" },
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"red","value":0.08}] }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_portfolio_drawdown_ratio", "legendFormat": "Drawdown" }]
    },
    {
      "id": 20, "type": "bargauge", "title": "Agent PnL",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":0},{"color":"green","value":1}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_agent_pnl_usd", "legendFormat": "{{agent}}" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" }
    },
    {
      "id": 21, "type": "bargauge", "title": "Agent Win Rate",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":0.35},{"color":"green","value":0.5}] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_agent_win_rate", "legendFormat": "{{agent}}" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" }
    },
    {
      "id": 22, "type": "bargauge", "title": "Agent Capital Allocation",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 0.5, "color": { "mode": "continuous-BlPu" } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "polymarket_agent_allocation_ratio", "legendFormat": "{{agent}}" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" }
    },
    {
      "id": 30, "type": "timeseries", "title": "Trades per Minute",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1.5, "fillOpacity": 10 } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "rate(polymarket_trades_total[1m]) * 60", "legendFormat": "{{agent}} {{side}}" }]
    },
    {
      "id": 31, "type": "timeseries", "title": "Cycle Duration (ms)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1.5 } }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(polymarket_cycle_duration_ms_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(polymarket_cycle_duration_ms_bucket[5m]))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(polymarket_cycle_duration_ms_bucket[5m]))", "legendFormat": "p99" }
      ]
    }
  ]
}
